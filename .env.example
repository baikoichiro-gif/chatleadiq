# App
NODE_ENV=development
APP_URL=http://localhost:3000
WEB_PORT=3000
API_PORT=4000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-secret

# Database - Local MySQL example
DATABASE_URL=mysql://root:@localhost:3306/chatleadiq

# Database - Hosting MySQL example
# DATABASE_URL=mysql://db_user:db_password@db_host:3306/db_name

# AI
OPENAI_API_KEY=
GEMINI_API_KEY=
ENABLE_AI_ANALYZER=true
AI_ANALYZER_REQUIRED=false
AI_PROVIDER=auto
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# WhatsApp / Baileys QR login and AI analysis pipeline
BAILEYS_AUTH_DIR=./data/baileys-auth
BAILEYS_BROWSER=ubuntu
ANALYSIS_DEBOUNCE_MS=10000
ANALYSIS_BACKFILL_BATCH_SIZE=50
MAX_HISTORY_MESSAGES_PER_CHAT=100
ONLY_ANALYZE_RECENT_CHATS=true

# Safety
ENABLE_AUTO_SEND=false
FOLLOWUP_COOLDOWN_HOURS=24
MASK_PHONE_IN_LOGS=true
